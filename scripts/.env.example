# Copy to .env.local and fill in real values; start.ps1 auto-loads .env.local.
# DO NOT commit .env.local (already in .gitignore).

# image-to-3d provider: mock | tripo | hunyuan | meshy
IMAGE3D_PROVIDER=mock

# ---- Tripo3D ----
# Get the key at https://platform.tripo3d.ai (Bearer token, format tsk_xxx)
TRIPO_API_KEY=
# auto = let server pick default version
TRIPO_MODEL_VERSION=auto

# ---- Hunyuan (placeholder, not yet implemented) ----
HUNYUAN_SECRET_ID=
HUNYUAN_SECRET_KEY=

# ---- Meshy (placeholder) ----
MESHY_API_KEY=

# Server ports (optional overrides)
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=5173
