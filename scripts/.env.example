# Copy to .env.local and fill in real values; start.ps1 auto-loads .env.local.
# DO NOT commit .env.local (already in .gitignore).

# image-to-3d provider: mock | tripo | hunyuan | meshy
IMAGE3D_PROVIDER=mock

# ---- Tripo3D ----
# Get the key at https://platform.tripo3d.ai (Bearer token, format tsk_xxx)
TRIPO_API_KEY=
# auto = let server pick default version
TRIPO_MODEL_VERSION=auto

# ---- Hunyuan (placeholder, not yet implemented) ----
HUNYUAN_SECRET_ID=
HUNYUAN_SECRET_KEY=

# ---- Meshy (placeholder) ----
MESHY_API_KEY=

# Server ports (optional overrides)
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ---- Project-local caches ----
# start.ps1 resolves these relative paths against the repository root.
XDG_CACHE_HOME=.cache
HF_HOME=.cache/huggingface
HF_HUB_CACHE=.cache/huggingface/hub
HUGGINGFACE_HUB_CACHE=.cache/huggingface/hub
HF_DATASETS_CACHE=.cache/huggingface/datasets
TRANSFORMERS_CACHE=.cache/huggingface/transformers
DIFFUSERS_CACHE=.cache/huggingface/diffusers
TORCH_HOME=.cache/torch
PIP_CACHE_DIR=.cache/pip
NPM_CONFIG_CACHE=.cache/npm
MPLCONFIGDIR=.cache/matplotlib
CONDA_PKGS_DIRS=.cache/conda/pkgs
CONDA_ENVS_PATH=.conda/envs
TEMP=.cache/tmp
TMP=.cache/tmp
HF_HUB_DISABLE_XET=1
HF_ENDPOINT=https://hf-mirror.com

# ---- CatVTON virtual try-on ----
# For RTX 4060 Laptop, start with bf16 + TF32. If out of memory, set 512x768.
USE_CONDA_WRAPPER=false
CATVTON_CONDA_ENV=catvton
CATVTON_BASE_MODEL_PATH=booksforcharlie/stable-diffusion-inpainting
CATVTON_RESUME_PATH=zhengchong/CatVTON
CATVTON_ATTN_CKPT_VERSION=mix
CATVTON_WIDTH=768
CATVTON_HEIGHT=1024
CATVTON_STEPS=50
CATVTON_GUIDANCE_SCALE=2.5
CATVTON_MIXED_PRECISION=bf16
CATVTON_ALLOW_TF32=true
CATVTON_SKIP_SAFETY_CHECK=true
